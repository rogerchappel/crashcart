{
  "name": "crashcart",
  "version": "0.1.0",
  "description": "Privacy-preserving local CLI failure triage bundle generator.",
  "type": "module",
  "bin": {
    "crashcart": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/tests/*.test.js",
    "smoke": "npm run build && (node dist/src/cli.js run --out .crashcart/smoke -- node fixtures/failing-command.js || test $? -eq 1) && node dist/src/cli.js inspect .crashcart/smoke/crashcart.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "diagnostics",
    "triage",
    "logs",
    "redaction",
    "privacy",
    "typescript",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/crashcart.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/crashcart/issues"
  },
  "homepage": "https://github.com/rogerchappel/crashcart#readme"
}
